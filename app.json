{
  "expo": {
    "name": "Aurora Australis Predictor",
    "slug": "aurora-australis-predictor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location helps estimate Aurora Australis visibility for your latitude.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Your location helps estimate Aurora Australis visibility for your latitude."
      },
      "bundleIdentifier": "com.auroraaustralis.predictor"
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.auroraaustralis.predictor"
    },
    "scheme": "auroraaustralispredictor",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "./plugins/withPinnedGradleWrapper"
    ]
  }
}
